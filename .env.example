# Placetel SIP-Konfiguration
# SIP-Accounts in deinem Placetel-Portal anlegen:
# Portal → Benutzer → Neuer Benutzer → SIP-Daten notieren

PLACETEL_SIP_DOMAIN=sip.placetel.de
PLACETEL_WSS=wss://sip.placetel.de/ws

# SIP-Zugangsdaten pro Nutzer (Benutzername = SIP-Durchwahl oder Username aus Portal)
PLACETEL_USER_TYRONE=
PLACETEL_PASS_TYRONE=
PLACETEL_USER_KEVIN=
PLACETEL_PASS_KEVIN=
PLACETEL_USER_MARC=
PLACETEL_PASS_MARC=
PLACETEL_USER_TIMO=
PLACETEL_PASS_TIMO=
